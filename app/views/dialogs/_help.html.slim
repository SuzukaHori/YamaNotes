dialog class='p-4 w-[640px] rounded-lg backdrop:bg-black/80 relative' data-modal-target='dialog'
  h2.text-2xl.font-bold.text-center.my-2.mx-auto = t('.heading')
  button.focus:outline-none.absolute.top-0.right-0.p-2.m-2.hover:bg-gray-100 data-action="click->modal#close" autofocus=true
    i.fa-solid.fa-xmark.fa-2xl
  ol.list-disc.pl-6.leading-8
    li.mb-2
      = t('.press_arrival_prefix')
      button.btn-primary.inline-block.mx-1
        = t('.arrival_button_label')
      = t('.press_arrival_suffix')
    li.mb-2
      a.link-important.mx-1
        = t('.memo_button_label')
      = t('.memo_button_suffix')
    li.mb-2
      = t('.mistake_correction_prefix')
      = link_to t('.arrivals_list_link'), arrivals_path, class: 'text-blue-600 underline hover:text-gray-400'
      = t('.mistake_correction_suffix')
    li.mb-2
      = t('.reset_settings_note')
    li.mb-2
      p.inline = t('.walking_guide_prefix')
      = link_to 'https://scrapbox.io/yamanotes/%E5%B1%B1%E6%89%8B%E7%B7%9A%E5%BE%92%E6%AD%A9%E4%B8%80%E5%91%A8%E3%81%AE%E6%BA%96%E5%82%99%E3%83%AA%E3%82%B9%E3%83%88',
        class: 'text-blue-600 underline hover:text-gray-400', target: '_blank', rel: 'noopener'
        = t('.preparation_list')
      p.inline ・
      = link_to 'https://scrapbox.io/yamanotes/%E5%B1%B1%E6%89%8B%E7%B7%9A%E4%B8%80%E5%91%A8%E3%81%AE%E6%B3%A8%E6%84%8F',
        class: 'text-blue-600 underline hover:text-gray-400', target: '_blank', rel: 'noopener'
        = t('.caution_note')
      = t('.walking_guide_suffix')
